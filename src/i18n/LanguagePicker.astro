---
import { getLangFromUrl, locales, useTranslation, slugify } from ".";
import { getCollection } from "astro:content";
const currentLang = getLangFromUrl(Astro.url);

// Build a map of route slugs per language based on translation labels
const SLUGS: Record<string, Record<string, string>> = {};
const routeKeys = new Set<string>();
for (const [l] of Object.entries(locales)) {
  const t = await useTranslation(l as any);
  SLUGS[l] = {} as Record<string, string>;
}
const ROUTE_KEYS = Array.from(routeKeys);

const path = Astro.url.pathname;
function detectRouteKey() {
  const parts = path.split("/").filter(Boolean);
  const langInPath = parts[0] || currentLang;
  const slug = decodeURIComponent(parts[1] || "");

  for (const key of ROUTE_KEYS) {
    if (key === "home" && (slug === "" || slug === undefined)) return "home";
    if (SLUGS[langInPath] && SLUGS[langInPath][key] === slug) return key;
  }
  return null;
}

const routeKey = detectRouteKey();

async function getPath(lang: string) {
  let newPath = `/${lang}/`;
  if (routeKey && routeKey !== "home") {
    const newSlug = SLUGS[lang] && SLUGS[lang][routeKey];
    if (newSlug) newPath = `/${lang}/${newSlug}/`;
  } else if (!routeKey) {
    const pathParts = path.split("/").filter(Boolean);
    const pagePath = pathParts.slice(1).join("/");

    if (pathParts[1] === "news" && pathParts[2]) {
      const currentSlug = pathParts[2];
      const targetLang = lang === "es" ? "es" : "en";
      const currentCollection = `news-${currentLang}` as "news-es" | "news-en";
      const targetCollection = `news-${targetLang}` as "news-es" | "news-en";

      try {
        const currentNews = await getCollection(currentCollection);
        const targetNews = await getCollection(targetCollection);

        const currentArticle = currentNews.find(
          (article) => article.id.replace(".md", "") === currentSlug,
        );

        if (currentArticle && currentArticle.data.id) {
          const equivalentArticle = targetNews.find(
            (article) => article.data.id === currentArticle.data.id,
          );

          if (equivalentArticle) {
            newPath = `/${lang}/News/${equivalentArticle.id.replace(".md", "")}/`;
          } else {
            newPath = `/${lang}/News/`;
          }
        } else {
          newPath = `/${lang}/News/`;
        }
      } catch (error) {
        newPath = `/${lang}/News/`;
      }
    } else if (pagePath) {
      newPath = `/${lang}/${pagePath}/`;
    }
  }
  return newPath;
}

const otherLangs = await Promise.all(
  Object.entries(locales)
    .filter(([lang]) => lang !== currentLang)
    .map(async ([lang, label]) => ({
      lang,
      label,
      path: await getPath(lang),
    }))
);
---

<!-- Desktop: hover dropdown | Mobile: click accordion -->
<div class="language-picker relative w-full lg:w-auto" data-language-picker>

  <!-- Desktop trigger (hover) -->
  <div class="hidden lg:block group">
    <span
      class="flex items-center text-sm italic p-4 transition-colors duration-300 border-b-2 border-transparent hover:text-[var(--color-primary)]! hover:border-[var(--color-primary)] cursor-default gap-1"
    >
      {currentLang.toUpperCase()}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="fill-current h-4 w-4 transition-transform group-hover:rotate-180 duration-300"
        viewBox="0 0 24 24"
      >
        <path class="group-hover:fill-[var(--color-primary)] fill-black" d="m12 15l5-5H7z" />
      </svg>
    </span>
    <div
      class="bg-[var(--color-primary)]/75 backdrop-blur-sm absolute w-full top-full left-0 shadow-xl rounded-b-sm flex flex-col opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-20"
    >
      {otherLangs.map(({ lang, path }) => (
        <a
          href={path}
          class="block py-2 w-full text-center text-xs italic !text-white transition-colors hover:bg-gray-600 whitespace-nowrap"
        >
          {lang.toUpperCase()}
        </a>
      ))}
    </div>
  </div>

  <!-- Mobile trigger (click accordion) -->
  <div class="lg:hidden flex flex-col border-b border-gray-100">
    <button
      class="mobile-lang-btn flex items-center justify-between text-lg font-medium p-2 transition-colors duration-300 border-b-2 border-transparent hover:text-[var(--color-primary)]! hover:border-[var(--color-primary)] w-full text-left"
      data-language-toggle
    >
      <span>{currentLang.toUpperCase()}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="language-arrow h-5 w-5 transition-transform duration-300 fill-current"
        viewBox="0 0 24 24"
      >
        <path d="m12 15l5-5H7z" />
      </svg>
    </button>
    <div
      class="language-menu max-h-0 overflow-hidden transition-all duration-300 flex flex-col border-l-2 border-[var(--color-primary)] ml-2"
      data-language-menu
    >
      <div class="flex flex-col">
        {otherLangs.map(({ lang, path }) => (
          <a
            href={path}
            class="block text-sm italic w-full py-2 pl-4 transition-colors duration-300 text-gray-600 hover:bg-[var(--color-primary)]/25 hover:text-[var(--color-primary)]!"
          >
            {lang.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </div>

</div>

<script is:inline>
  (function () {
    function setupPicker(picker) {
      if (picker.dataset.initialized) return;
      picker.dataset.initialized = "true";

      const toggle = picker.querySelector("[data-language-toggle]");
      const menu = picker.querySelector("[data-language-menu]");
      const arrow = picker.querySelector(".language-arrow");

      if (!toggle || !menu) return;

      toggle.addEventListener("click", function () {
        const isOpen = menu.style.maxHeight && menu.style.maxHeight !== "0px";
        if (isOpen) {
          menu.style.maxHeight = "0px";
          arrow?.classList.remove("rotate-180");
        } else {
          menu.style.maxHeight = menu.scrollHeight + "px";
          arrow?.classList.add("rotate-180");
        }
      });
    }

    function init() {
      document.querySelectorAll("[data-language-picker]").forEach(setupPicker);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    document.addEventListener("astro:page-load", init);
  })();
</script>
