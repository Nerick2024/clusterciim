---
import { getLangFromUrl, locales, useTranslation, slugify } from ".";
import { getCollection } from "astro:content";
const currentLang = getLangFromUrl(Astro.url);

// Build a map of route slugs per language based on translation labels
const SLUGS: Record<string, Record<string, string>> = {};
const routeKeys = new Set<string>();
for (const [l] of Object.entries(locales)) {
  const t = await useTranslation(l as any);
  SLUGS[l] = {} as Record<string, string>;
}
const ROUTE_KEYS = Array.from(routeKeys);

const path = Astro.url.pathname;
function detectRouteKey() {
  const parts = path.split("/").filter(Boolean);
  const langInPath = parts[0] || currentLang;
  const slug = decodeURIComponent(parts[1] || "");

  for (const key of ROUTE_KEYS) {
    if (key === "home" && (slug === "" || slug === undefined)) return "home";
    if (SLUGS[langInPath] && SLUGS[langInPath][key] === slug) return key;
  }
  return null;
}

const routeKey = detectRouteKey();

async function getPath(lang: string) {
  let newPath = `/${lang}/`;
  if (routeKey && routeKey !== "home") {
    const newSlug = SLUGS[lang] && SLUGS[lang][routeKey];
    if (newSlug) newPath = `/${lang}/${newSlug}/`;
  } else if (!routeKey) {
    const pathParts = path.split("/").filter(Boolean);
    const pagePath = pathParts.slice(1).join("/");
    
    // Check if this is a news article page
    if (pathParts[1] === "news" && pathParts[2]) {
      const currentSlug = pathParts[2];
      const targetLang = lang === 'es' ? 'es' : 'en';
      const currentCollection = `news-${currentLang}` as 'news-es' | 'news-en';
      const targetCollection = `news-${targetLang}` as 'news-es' | 'news-en';
      
      try {
        const currentNews = await getCollection(currentCollection);
        const targetNews = await getCollection(targetCollection);
        
        // Find current article
        const currentArticle = currentNews.find(article => 
          article.id.replace('.md', '') === currentSlug
        );
        
        if (currentArticle && currentArticle.data.id) {
          // Find equivalent article in target language using the same id
          const equivalentArticle = targetNews.find(article => 
            article.data.id === currentArticle.data.id
          );
          
          if (equivalentArticle) {
            newPath = `/${lang}/News/${equivalentArticle.id.replace('.md', '')}/`;
          } else {
            newPath = `/${lang}/News/`; // Fallback to news list
          }
        } else {
          newPath = `/${lang}/News/`; // Fallback to news list
        }
      } catch (error) {
        newPath = `/${lang}/News/`; // Fallback to news list
      }
    } else if (pagePath) {
      newPath = `/${lang}/${pagePath}/`;
    }
  }
  return newPath;
}
---

<div class="language-picker relative w-full lg:w-auto group" data-language-picker>
  <button
    class="language-toggle button-glass flex items-center justify-center gap-2 italic text-sm "
    data-language-toggle
  >
    <p class="group-hover:!text-[var(--color-primary)]">{currentLang.toUpperCase()}</p>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="language-arrow fill-current h-4 w-4 transition-transform duration-300 group"
      viewBox="0 0 24 24"
    >
      <path
        class="fill-black group-hover:fill-[var(--color-primary)]"
        d="m12 15l5-5H7z"></path>
    </svg>
  </button>
  <div
    class="language-menu bottom-full mb-2 lg:top-full lg:bottom-auto lg:mb-0 left-0 z-20 absolute flex w-full flex-col gap-2 opacity-0 bg-[var(--color-primary)]/75 backdrop-blur-sm rounded-b-sm transition-all duration-200 pointer-events-none"
    data-language-menu
  >
    {
      Object.entries(locales).map(async ([lang, label]) => {
        if (lang !== currentLang) {
          const linkPath = await getPath(lang);
          return (
            <a
              href={linkPath}
              class="block text-center !text-white w-full italic text-xs py-2 transition-colors hover:bg-black/20"
            >
              {lang.toUpperCase()}
            </a>
          );
        }
      })
    }
  </div>
</div>

<style>
  @media (min-width: 1024px) {
    .language-picker:hover .language-menu {
      opacity: 1;
      pointer-events: auto;
    }
    .language-picker:hover .language-arrow {
      transform: rotate(180deg);
    }
  }
</style>

<script is:inline>
  (function () {
    let initialized = false;

    function setupPicker(picker) {
      if (picker.dataset.initialized) return;
      picker.dataset.initialized = "true";

      const toggle = picker.querySelector("[data-language-toggle]");
      const menu = picker.querySelector("[data-language-menu]");
      const arrow = picker.querySelector("[data-language-arrow]");

      if (!toggle || !menu || !arrow) return;

      // Solo agregar funcionalidad de click en móvil
      const isMobile = () => window.innerWidth < 1024;

      toggle.addEventListener("click", function (e) {
        if (!isMobile()) return; // En desktop usar hover

        e.preventDefault();
        e.stopPropagation();

        const isOpen = menu.classList.contains("opacity-100");

        if (isOpen) {
          menu.classList.remove("opacity-100", "pointer-events-auto");
          menu.classList.add("opacity-0", "pointer-events-none");
          arrow.classList.remove("rotate-180");
        } else {
          menu.classList.remove("opacity-0", "pointer-events-none");
          menu.classList.add("opacity-100", "pointer-events-auto");
          arrow.classList.add("rotate-180");
        }
      });

      document.addEventListener("click", function (e) {
        if (!isMobile() || !picker.contains(e.target)) {
          menu.classList.remove("opacity-100", "pointer-events-auto");
          menu.classList.add("opacity-0", "pointer-events-none");
          arrow.classList.remove("rotate-180");
        }
      });
    }

    function init() {
      if (initialized) return;
      initialized = true;

      const pickers = document.querySelectorAll("[data-language-picker]");
      pickers.forEach(setupPicker);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
