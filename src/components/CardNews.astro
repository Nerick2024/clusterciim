---
interface Props {
  title: string;
  description: string;
  image: string;
  slug: string;
  lang: string;
}

const { title, description, image, slug, lang } = Astro.props;
---

<div class="flex flex-col bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
  <img src={image} alt={title} class="w-full h-48 object-cover" />
  <div class="flex flex-col flex-1 p-6">
    <h2 class="text-2xl font-bold mb-2">{title}</h2>
    <p class="text-gray-600 mb-4 flex-1">{description}</p>
    <a href={`/${lang}/news/${slug}`} class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors text-center">
      Leer más
    </a>
  </div>
</div>
