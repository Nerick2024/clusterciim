---
import { getLangFromUrl, useTranslation } from "@/i18n";
const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section
  id="Solutions"
  class="container max-w-7xl text-white mx-auto px-6 py-20 md:py-32 relative"
>
  <!-- Header -->
  <div class="max-w-4xl mb-16 md:mb-24" data-aos="fade-up" data-aos-duration="800">
    <div class="inline-block mb-4">
      <span
        class="text-xs md:text-sm uppercase tracking-[0.3em] text-gray-400 font-light"
        >Our Solutions</span
      >
    </div>
    <h2 class="text-4xl md:text-5xl lg:text-7xl font-bold mb-6 leading-tight bg-gradient-to-r from-gray-300 via-white to-gray-300 bg-clip-text text-transparent">
      {i18n.SOLUTIONS.TITLE}
    </h2>
    <p class="text-base md:text-lg text-gray-300 leading-relaxed max-w-3xl">
      {i18n.SOLUTIONS.DESCRIPTION}
    </p>
  </div>

  <!-- Solutions Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
    {
      i18n.SOLUTIONS.LABELS.map((solution, index) => (
        <div data-aos="fade-up" data-aos-duration="800" data-aos-delay={index * 100} class="h-full card-3d-container" style="perspective: 1500px;">
          <div class="card-3d group relative bg-gradient-to-br from-zinc-800/50 to-zinc-900/70 backdrop-blur-sm rounded-2xl p-8 border border-zinc-700/70 hover:border-zinc-600/90 hover:shadow-2xl hover:shadow-zinc-800/50 h-full" style="transform-style: preserve-3d;">
          <div class="mb-6 relative card-3d-icon" style="transform-style: preserve-3d;">
            <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-zinc-800 to-zinc-900 flex items-center justify-center shadow-lg">
              <img
                loading="lazy"
                src={solution.IMG}
                alt={solution.TITLE}
                class="w-8 h-8 object-contain filter brightness-110"
              />
            </div>
          </div>

          <h3 class="card-3d-title text-xl md:text-2xl font-bold mb-4 leading-tight" style="transform-style: preserve-3d;">
            {solution.TITLE}
          </h3>
          <p class="card-3d-text text-sm md:text-base text-gray-400 leading-relaxed" style="transform-style: preserve-3d;">
            {solution.DESCRIPTION}
          </p>

          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-zinc-700/0 via-zinc-600/0 to-zinc-700/0 group-hover:from-zinc-600/15 group-hover:via-zinc-500/8 group-hover:to-zinc-600/15 transition-all duration-500 pointer-events-none" />
        </div>
        </div>
      ))
    }
  </div>
</section>
