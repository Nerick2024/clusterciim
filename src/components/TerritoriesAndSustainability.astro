---
import { getLangFromUrl, useTranslation } from "@/i18n";
const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section
  id="TerritoriesAndSustainability"
  class="container max-w-7xl text-white mx-auto px-6 py-20 md:py-32 relative"
>
  <!-- Header -->
  <div class="mb-16 md:mb-20" data-aos="fade-up" data-aos-duration="800">
    <div class="inline-block mb-4">
      <span
        class="text-xs md:text-sm uppercase tracking-[0.3em] text-gray-400 font-light"
        >Sustainability</span
      >
    </div>
    <h2
      class="text-4xl md:text-5xl lg:text-7xl font-bold leading-tight mb-8 bg-gradient-to-r from-gray-300 via-white to-gray-300 bg-clip-text text-transparent"
    >
      {i18n.TERRITORIES_SUSTAINABILITY.TITLE}
    </h2>
  </div>

  <!-- Content Cards -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Card 1 -->
    <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <div
        class="group card-grain relative bg-white/5 backdrop-blur-sm rounded-3xl p-10 md:p-12 border border-zinc-700/70 hover:border-zinc-600/90 transition-all duration-500 hover:shadow-2xl hover:shadow-zinc-800/50"
      >
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full aspect-square opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-0"
          style="background: radial-gradient(circle, var(--grain-light-primary) 0%, var(--grain-light-secondary) 30%, rgba(0,0,0,0.3) 80%);"
        >
        </div>
        <p
          class="text-base md:text-lg text-gray-300 leading-relaxed relative z-10"
        >
          {i18n.TERRITORIES_SUSTAINABILITY.TEXT}
        </p>
      </div>
    </div>

    <!-- Card 2 -->
    <div
      data-aos="fade-up"
      data-aos-duration="800"
      data-aos-delay="200"
      class="h-full"
    >
      <div
        class="group card-grain relative bg-white/5 backdrop-blur-sm rounded-3xl p-10 md:p-12 border border-zinc-700/70 hover:border-zinc-600/90 transition-all duration-500 hover:shadow-2xl hover:shadow-zinc-800/50 h-full"
      >
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full aspect-square opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-0"
          style="background: radial-gradient(circle, var(--grain-light-primary) 0%, var(--grain-light-secondary) 30%, rgba(0,0,0,0.3) 80%);"
        >
        </div>

        <p
          class="text-base md:text-lg text-gray-300 leading-relaxed relative z-10"
        >
          {i18n.TERRITORIES_SUSTAINABILITY.TEXT_2}
        </p>
      </div>
    </div>
  </div>
</section>
