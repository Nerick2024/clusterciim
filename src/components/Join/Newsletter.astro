---
import { getLangFromUrl, useTranslation } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section
  class="max-w-7xl mx-auto px-6 flex flex-col mt-32 lg:mt-44 lg:flex-row gap-6 items-center justify-between"
>
  <!-- Formulario -->
  <div class="flex flex-col w-full lg:w-[28%] gap-6">
    <h2>
      {i18n.NEWSLETTER.FORM_TITLE}
    </h2>

    <form class="flex flex-col gap-5" method="POST">
      <div class="flex flex-col">
        <label for="nombre" class="text-sm">
          {i18n.NEWSLETTER.NAME_LABEL}
        </label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          class="border border-gray-400 w-full px-3 py-2 text-sm focus:outline-none focus:border-gray-700 bg-white"
        />
      </div>

      <div class="flex flex-col">
        <label for="email" class="text-sm">
          {i18n.NEWSLETTER.EMAIL_LABEL}
        </label>
        <input
          id="email"
          name="email"
          type="email"
          class="border border-gray-400 w-full px-3 py-2 text-sm focus:outline-none focus:border-gray-700 bg-white"
        />
      </div>

      <button
        type="submit"
        class="bg-[var(--color-primary)] hover:bg-gray-600 !text-white text-sm font-medium px-6 py-2.5 w-fit transition-colors duration-200 cursor-pointer"
      >
        {i18n.NEWSLETTER.SUBMIT}
      </button>
    </form>
  </div>

  <!-- Texto -->
  <div class="flex flex-col items-center lg:flex-row w-full lg:w-[72%] gap-6">
    <div
      class="w-full md:w-1/3 h-fit rounded-lg overflow-hidden aspect-square bg-gradient-to-b from-[var(--color-primary)]/10 to-[var(--color-primary)]/50"
    >
      <img
        loading="lazy"
        src="/Team/Directors/hector.webp"
        alt="director"
        class="h-full w-full object-contain"
      />
    </div>

    <div class="flex lg:w-2/3 flex-col gap-4">
      <h2>
        {i18n.NEWSLETTER.TITLE}
      </h2>
      <p class="font-bold">{i18n.NEWSLETTER.SUBTITLE}</p>
      <p set:html={i18n.NEWSLETTER.BODY} />
    </div>
  </div>
</section>
