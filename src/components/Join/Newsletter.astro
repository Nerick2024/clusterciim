---
import { getLangFromUrl, useTranslation } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section
  class="max-w-7xl mx-auto px-6 flex flex-col mt-32 lg:mt-44 lg:flex-row gap-6 items-center justify-between"
>
  <!-- Formulario -->
  <div class="flex flex-col w-full lg:w-[28%] gap-6">
    <h2>
      {i18n.NEWSLETTER.FORM_TITLE}
    </h2>

    <form id="newsletter-form" class="flex flex-col gap-5">
      <div class="flex flex-col">
        <label for="name" class="text-sm">
          {i18n.NEWSLETTER.NAME_LABEL}
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="border border-gray-400 w-full px-3 py-2 text-sm focus:outline-none focus:border-gray-700 bg-white"
        />
      </div>

      <div class="flex flex-col">
        <label for="email" class="text-sm">
          {i18n.NEWSLETTER.EMAIL_LABEL}
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="border border-gray-400 w-full px-3 py-2 text-sm focus:outline-none focus:border-gray-700 bg-white"
        />
      </div>

      <button
        id="newsletter-submit"
        data-text={i18n.NEWSLETTER.SUBMIT}
        type="submit"
        class="bg-[var(--color-primary)] hover:bg-gray-600 !text-white text-sm font-medium px-6 py-2.5 w-fit transition-colors duration-200 cursor-pointer"
      >
        {i18n.NEWSLETTER.SUBMIT}
      </button>

      <p id="newsletter-status" class="text-sm hidden"></p>
    </form>
  </div>

  <!-- Texto -->
  <div class="flex flex-col items-center lg:flex-row w-full lg:w-[72%] gap-6">
    <div
      class="w-full md:w-1/3 h-fit rounded-lg overflow-hidden aspect-square bg-gradient-to-b from-[var(--color-primary)]/10 to-[var(--color-primary)]/50"
    >
      <img
        loading="lazy"
        src="/Team/Directors/hector.webp"
        alt="director"
        class="h-full w-full object-contain"
      />
    </div>

    <div class="flex lg:w-2/3 flex-col gap-4">
      <h2>
        {i18n.NEWSLETTER.TITLE}
      </h2>
      <p class="font-bold">{i18n.NEWSLETTER.SUBTITLE}</p>
      <p set:html={i18n.NEWSLETTER.BODY} />
    </div>
  </div>
</section>

<script is:inline>
  const GAS_URL =
    "https://script.google.com/macros/s/AKfycbwBWgZ4i8p0rz-qyx13IxQV3k4xVnj7xi6iqHt4l-ACjVQ_WkBLOAnCT8ZIMuLC3Z6H3w/exec";

  const form = document.getElementById("newsletter-form");
  const statusEl = document.getElementById("newsletter-status");
  const submitBtn = document.getElementById("newsletter-submit");

  const originalText = submitBtn.dataset.text;

  function setStatus(message, type) {
    statusEl.textContent = message;
    statusEl.classList.remove("hidden", "text-green-600", "text-red-600");
    statusEl.classList.add(
      type === "success" ? "text-green-600" : "text-red-600",
    );
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const fd = new FormData(form);
    const name = (fd.get("name") || "").toString().trim();
    const email = (fd.get("email") || "").toString().trim();

    if (!name || !email) {
      setStatus("Completa nombre y email.", "error");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Enviando...";
    statusEl.classList.add("hidden");

    try {
      const body = new URLSearchParams();
      body.append("name", name);
      body.append("email", email);

      await fetch(GAS_URL, {
        method: "POST",
        mode: "no-cors",
        headers: {
          "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
        },
        body,
      });

      form.reset();
      setStatus("Te suscribiste correctamente.", "success");
    } catch (err) {
      setStatus("No se pudo enviar. Intenta de nuevo.", "error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
