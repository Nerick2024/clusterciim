---
import { getLangFromUrl, useTranslation } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section
  class="max-w-7xl mx-auto flex flex-col mt-44 lg:flex-row gap-6 items-center justify-between"
>
  <!-- Formulario -->
  <div class="flex flex-col w-full lg:w-1/4 gap-6">
    <h1 class="text-3xl font-bold">
      {i18n.NEWSLETTER.FORM_TITLE}
    </h1>

    <form class="flex flex-col gap-5" method="POST">
      <div class="flex flex-col">
        <label for="nombre" class="text-sm">
          {i18n.NEWSLETTER.NAME_LABEL}
        </label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          class="border border-gray-400 w-full px-3 py-2 text-sm focus:outline-none focus:border-gray-700 bg-white"
        />
      </div>

      <div class="flex flex-col">
        <label for="email" class="text-sm">
          {i18n.NEWSLETTER.EMAIL_LABEL}
        </label>
        <input
          id="email"
          name="email"
          type="email"
          class="border border-gray-400 w-full px-3 py-2 text-sm focus:outline-none focus:border-gray-700 bg-white"
        />
      </div>

      <button
        type="submit"
        class="bg-[var(--color-primary)] hover:bg-black !text-white text-sm font-medium px-6 py-2.5 w-fit transition-colors duration-200 cursor-pointer"
      >
        {i18n.NEWSLETTER.SUBMIT}
      </button>
    </form>
  </div>

  <!-- Texto -->
  <div class="flex flex-col lg:flex-row w-full lg:w-3/4 gap-6">
    <img
      src="https://ccic.cat/wp-content/uploads/2023/03/PereArmora.jpg"
      alt="director"
      class="w-1/3 h-auto object-contain"
    />
    <div class="flex lg:w-2/3 flex-col gap-4">
      <h2 class="text-3xl font-bold">
        {i18n.NEWSLETTER.TITLE}
      </h2>
      <p class="font-bold">{i18n.NEWSLETTER.SUBTITLE}</p>
      <p class="text-sm" set:html={i18n.NEWSLETTER.BODY} />
    </div>
  </div>
</section>
