---
import { getLangFromUrl, useTranslation } from "@/i18n";

function createSlug(name: string) {
  return name
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-")
    .trim();
}

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section class="mb-20 px-6 mt-12 md:mt-28 lg:mt-44">
  <div class="max-w-7xl mx-auto flex flex-col items-center gap-6">
    <h2>
      {i18n.TEAM.TITLE}
    </h2>
    <p set:html={i18n.TEAM.DESCRIPTION} />

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full gap-6 mt-8"
    >
      {
        i18n.TEAM.DIRECTORS?.map((item: any) => (
          <a
            href={`/${lang}/Team/${createSlug(item.NAME)}`}
            data-aos="zoom-in"
            class="flex flex-row bg-white shadow-lg overflow-hidden hover:shadow-xl transition-shadow rounded-lg"
          >
            <div class="w-1/2">
              <img
                src={item.IMG}
                alt={item.NAME}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="w-1/2 p-3 flex flex-col gap-2">
              <h3 class="!text-lg lg:!text-2xl italic font-bold text-left">
                {item.NAME}
              </h3>
              <p class="italic font-semibold text-left">{item.POSITION}</p>
              <p
                class="!text-sm"
                set:html={
                  item.SEMBLANCE.length > 80
                    ? item.SEMBLANCE.substring(0, 80) + "..."
                    : item.SEMBLANCE
                }
              />
            </div>
          </a>
        ))
      }
    </div>

    <a
      href={`/${lang}/Join`}
      class="bg-[var(--color-primary)] hover:bg-gray-600 !text-white text-sm italic font-bold px-10 py-4 transition-colors duration-300"
    >
      {i18n.TEAM.CTA}
    </a>
  </div>
</section>
