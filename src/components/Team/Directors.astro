---
import { getLangFromUrl, useTranslation } from "@/i18n";

function createSlug(name: string) {
  return name
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-")
    .trim();
}

function splitName(name: string): [string, string] {
  const words = name.trim().split(/\s+/);
  // Si la segunda palabra es un conector (≤2 letras), agrupar palabras 2 y 3 en la segunda línea
  if (words[1] && words[1].length <= 2 && words[2]) {
    return [words[0], words.slice(1, 3).join(" ")];
  }
  return [words[0] ?? "", words[1] ?? ""];
}

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);
---

<section class="mb-20 mx-6 mt-32 lg:mt-44">
  <div class="max-w-7xl mx-auto flex flex-col items-center gap-6">
    <h2>
      {i18n.TEAM.TITLE}
    </h2>
    <p set:html={i18n.TEAM.DESCRIPTION} />

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 w-full gap-6 mt-8"
    >
      {
        i18n.TEAM.DIRECTORS?.map((item: any) => (
          <div data-aos="zoom-in">
            <a
              href={`/${lang}/Team/${createSlug(item.NAME)}`}
              class="flex flex-row bg-white shadow-lg overflow-hidden hover:shadow-xl rounded-lg hover:-translate-y-2 transition-all duration-300"
            >
              <div
                class="w-1/2 bg-gradient-to-b from-[var(--color-primary)]/10 to-[var(--color-primary)]/50"
                transition:name={`director-photo-${createSlug(item.NAME)}`}
              >
                <img
                  loading="lazy"
                  src={item.IMG}
                  alt={item.NAME}
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="w-1/2 p-3 flex flex-col gap-2">
                <h3 class="!text-lg lg:!text-2xl italic font-bold text-left flex flex-col leading-tight">
                  {splitName(item.NAME)[0]} <br />
                  {splitName(item.NAME)[1]}
                </h3>
                <p class="italic !text-black/75 font-semibold text-left">
                  {item.POSITION}
                </p>
                <p
                  class="!text-sm"
                  set:html={
                    item.SEMBLANCE.length > 80
                      ? item.SEMBLANCE.substring(0, 80) + "..."
                      : item.SEMBLANCE
                  }
                />
              </div>
            </a>
          </div>
        ))
      }
    </div>

    <a
      href={`/${lang}/Join`}
      class="bg-[var(--color-primary)] hover:bg-gray-600 !text-white text-sm italic font-bold px-10 py-4 transition-colors duration-300"
    >
      {i18n.TEAM.CTA}
    </a>
  </div>
</section>
