---
import { getLangFromUrl, useTranslation } from "@/i18n";
import { getCollection } from "astro:content";

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);

// Obtener las 5 noticias más recientes según el idioma
const collectionName = lang === "es" ? "news-es" : "news-en";
const allNews = await getCollection(collectionName);
const recentNews = allNews
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 5);
