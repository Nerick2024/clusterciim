<style>
  #hero {
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
      url("/Home/bg.webp");
    background-size: cover;
    background-position: top;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #mobile-carousel {
    overflow: hidden;
  }

  #mobile-track {
    will-change: transform;
  }

  .splide__slide--active-center .bg-white\/90 {
    transform: scale(1.05);
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.1),
      0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .splide__slide:not(.splide__slide--active-center) .bg-white\/90 {
    opacity: 0.7;
    transform: scale(0.95);
  }

  .splide__arrow {
    background: rgba(255, 255, 255, 0.8) !important;
    border: none !important;
    width: 32px !important;
    height: 32px !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
    transition: all 0.2s ease !important;
    z-index: 10 !important;
  }

  .splide__arrow:hover {
    background: rgba(255, 255, 255, 1) !important;
    transform: scale(1.1) !important;
  }

  .splide__arrow svg {
    width: 16px !important;
    height: 16px !important;
    color: #374151 !important;
  }
</style>

<script>
  import { Splide } from "@splidejs/splide";

  document.addEventListener("DOMContentLoaded", function () {
    // ── Desktop: Splide vertical ───────────────────────────────────────────
    if (window.innerWidth >= 1024) {
      const heroCarousel = new Splide("#hero-carousel", {
        type: "loop",
        direction: "ttb",
        height: "100%",
        autoplay: true,
        interval: 4000,
        pauseOnHover: true,
        arrows: true,
        pagination: false,
        perPage: 3,
        perMove: 1,
        focus: "center",
        gap: "0.1rem",
        padding: {
          top: "0.5rem",
          bottom: "0.5rem",
          left: "0.25rem",
          right: "0.25rem",
        },
        wheel: true,
        wheelSleep: 100,
        clones: 5,
        classes: {
          active: "splide__slide--active-center",
        },
      });
      heroCarousel.mount();
    }

    // ── Móvil: carrusel manual ─────────────────────────────────────────────
    const track = document.getElementById("mobile-track");
    const total = document.querySelectorAll(".mobile-slide").length;
    let current = 0;
    let startX = 0;

    function goTo(index: number) {
      current = (index + total) % total;
      (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
    }

    document
      .getElementById("mobile-next")
      ?.addEventListener("click", () => goTo(current + 1));
    document
      .getElementById("mobile-prev")
      ?.addEventListener("click", () => goTo(current - 1));

    track?.addEventListener(
      "touchstart",
      (e) => {
        startX = (e as TouchEvent).touches[0].clientX;
      },
      { passive: true },
    );

    track?.addEventListener("touchend", (e) => {
      const diff = startX - (e as TouchEvent).changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
    });

    setInterval(() => {
      if (window.innerWidth < 1024) goTo(current + 1);
    }, 4000);
  });
</script>
