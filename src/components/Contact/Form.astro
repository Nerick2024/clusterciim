---
import { getLangFromUrl, useTranslation } from "@/i18n";
const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);

const CONTACT = i18n.CONTACT;
---

<section class="max-w-7xl lg:mx-auto mx-6 mt-24 md:mt-28 lg:mt-44 mb-24">
  <div class="flex flex-col-reverse lg:flex-row gap-12">
    <!-- Columna izquierda (sin cambios) -->
    <aside class="flex flex-col gap-6 text-sm">
      <a
        href={`mailto:${CONTACT.EMAIL}`}
        class="!text-[var(--color-primary)] font-semibold italic"
      >
        {CONTACT.EMAIL}
      </a>
      {CONTACT.PERSONS.map((person: any) => (
        <div class="flex flex-col gap-0.5">
          <span class="font-semibold text-gray-800">{person.NAME}</span>
          <a href={`tel:${person.PHONE.replace(/\s/g, "")}`} class="!text-[var(--color-primary)] italic">
            {person.PHONE}
          </a>
        </div>
      ))}
      {CONTACT.LINKEDIN && (
        <a href={CONTACT.LINKEDIN} target="_blank" class="!text-[var(--color-primary)] italic">Linkedin</a>
      )}
      {CONTACT.ADDRESS && (
        <a href={CONTACT.ADDRESS_HREF} target="_blank" class="!text-[var(--color-primary)] italic leading-snug">
          {CONTACT.ADDRESS}
        </a>
      )}
    </aside>

    <!-- Columna derecha -->
    <div class="flex flex-col gap-6">
      <div>
        <h2>{CONTACT.FORM.HEADING}</h2>
        <p class="text-sm text-gray-700 mt-1 leading-relaxed">{CONTACT.FORM.DESCRIPTION}</p>
      </div>

      <!-- Mensajes de estado -->
      <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-800 text-sm px-4 py-3 rounded">
        ✅ ¡Mensaje enviado correctamente! Te contactaremos pronto.
      </div>
      <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-800 text-sm px-4 py-3 rounded">
        ❌ Hubo un error al enviar. Intenta de nuevo o escríbenos directamente.
      </div>

      <form id="contact-form" class="flex flex-col gap-4">
        <div class="flex flex-col gap-1">
          <label class="text-sm text-gray-700">{CONTACT.FORM.NAME_LABEL}</label>
          <input
            type="text"
            name="name"
            required
            class="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm text-gray-700">{CONTACT.FORM.EMAIL_LABEL}</label>
          <input
            type="email"
            name="email"
            required
            class="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm text-gray-700">{CONTACT.FORM.PHONE_LABEL}</label>
          <input
            type="tel"
            name="phone"
            class="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm text-gray-700">{CONTACT.FORM.MESSAGE_LABEL}</label>
          <textarea
            name="message"
            rows="8"
            required
            class="border border-gray-300 rounded px-3 py-2 text-sm resize-y focus:outline-none focus:border-[var(--color-primary)]"
          ></textarea>
        </div>

        <div>
          <button
            id="submit-btn"
            type="submit"
            class="bg-[var(--color-primary)] !text-white text-sm font-bold px-6 py-2 rounded hover:bg-gray-600 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            {CONTACT.FORM.SUBMIT_LABEL}
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  const PHP_URL = 'https://clusterciim.org/php/send-mail.php';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset mensajes
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    // Estado cargando
    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Enviando...';

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      message: formData.get('message'),
    };

    try {
      const response = await fetch(PHP_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = await response.json();

      if (result.success) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg.classList.remove('hidden');
        console.error(result.message);
      }
    } catch (err) {
      errorMsg.classList.remove('hidden');
      console.error(err);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>