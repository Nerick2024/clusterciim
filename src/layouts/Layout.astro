---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import { getLangFromUrl } from "@/i18n";
const lang = getLangFromUrl(Astro.url);
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="ClusterCIIM the future of the construction is here"
    />
    <meta
      name="keywords"
      content="BIM, construcción industrializada, ingeniería AECO, arquitectura sostenible, smart cities, VDC, Lean Construction, DFMA, gemelo digital, edificios inteligentes, IoT construcción, México"
    />
    <meta name="author" content="ClusterCIIM" />
    <link rel="icon" type="image/webp" href="/Logo/icon2.webp" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="ClusterCIIM the future of the construction is here"
    />
    <meta property="og:image" content="/logo/icon.webp" />
    <meta
      property="og:locale"
      content={lang === "es" ? "es_MX" : lang === "en" ? "en_US" : "de_DE"}
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta
      name="twitter:description"
      content="ClusterCIIM the future of the construction is here"
    />
    <meta name="twitter:image" content="/logo/icon.webp" />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#00010b" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />

    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <main style="flex: 1;">
      <slot />
    </main>
    <Footer />
  </body>
</html>
<script type="">
  import AOS from "aos";
  import "aos/dist/aos.css";

  document.addEventListener("DOMContentLoaded", function () {
    AOS.init();
  });
</script>
<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Karla:ital,wght@0,200..800;1,200..800&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap");
  :root {
    --color-text: #000000;
    --color-bg: #ffffff;
    --color-primary: #000000;
  }
  html,
  body {
    margin: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  html {
    background-color: var(--color-bg);
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
    overscroll-behavior-y: none;
  }

  h1,
  h2 {
    font-family: "Rubik", sans-serif;
  }

  h3,
  h4,
  h5,
  h6,
  p,
  span,
  li,
  a,
  button,
  input,
  textarea {
    font-family: "Karla", sans-serif;
    color: var(--color-text);
    font-size: 0.875rem;
  }

  .glass-effect {
    background-color: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(5px);
  }

  .button-glass {
    background-color: rgba(255, 255, 255, 0.08);
    border: solid 1px rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(5px);
  }

  /* Estilos para contenido de noticias */
  h1 {
    font-size: 3.5rem;
    font-weight: 700;
    text-align: left;
    width: 100%;
    line-height: 1;
  }

  h2 {
    font-size: 2.25rem;
    font-weight: 700;
    text-align: left;
    width: 100%;
    line-height: 1.1;
  }

  @media (min-width: 1024px) {
    h1 {
      font-size: 4.5rem;
    }

    h2 {
      font-size: 3rem;
    }

    h3,
    h4,
    h5,
    h6,
    p,
    span,
    li,
    a,
    button,
    input,
    textarea {
      font-size: 1.1rem;
    }
  }
</style>
