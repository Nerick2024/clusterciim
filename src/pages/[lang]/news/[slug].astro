---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import { getLangFromUrl } from "@/i18n";

export async function getStaticPaths() {
  const newsEs = await getCollection("news-es");
  const newsEn = await getCollection("news-en");

  const pathsEs = newsEs.map((entry) => ({
    params: { lang: "es", slug: entry.id.replace(".md", "") },
    props: { entry },
  }));

  const pathsEn = newsEn.map((entry) => ({
    params: { lang: "en", slug: entry.id.replace(".md", "") },
    props: { entry },
  }));

  return [...pathsEs, ...pathsEn];
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = getLangFromUrl(Astro.url);
---

<Layout title={entry.data.title}>
  <article class="max-w-7xl mx-auto px-6 py-12 lg:mt-28">
    <time class="text-gray-500 text-sm"
      >{entry.data.date.toLocaleDateString(lang)}</time
    >
    <div class="prose prose-lg max-w-none mt-6">
      <Content />
    </div>
  </article>
</Layout>

<style>
  /* Espaciado para contenido de markdown */
  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(h1) {
    font-size: 2.25rem;
    line-height: 1;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(h2) {
    font-size: 1.875rem;
    line-height: 1;
    font-weight: 700;
  }
  .prose :global(img) {
    margin-top: 2rem;
    margin-bottom: 2rem;

    width: 100%;
    margin-left: auto;
    margin-right: auto;
    display: block;
  }

  @media (min-width: 1024px) {
    .prose :global(h1) {
      font-size: 3rem;
    }
    .prose :global(h2) {
      font-size: 2.25rem;
    }
    .prose :global(img) {
      width: 80%;
    }
  }
</style>
