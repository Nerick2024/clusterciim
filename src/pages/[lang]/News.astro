---
import { getLangFromUrl, useTranslation } from "@/i18n";
import { translations } from "@/i18n/config";
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import CardNews from "@/components/CardNews.astro";

export function getStaticPaths() {
  return Object.keys(translations).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);

const collectionName = `news-${lang}` as "news-es" | "news-en";
const allNews = await getCollection(collectionName);
const sortedNews = allNews.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const categories = [
  ...new Set(
    allNews.flatMap((news) =>
      Array.isArray(news.data.category)
        ? news.data.category
        : [news.data.category],
    ),
  ),
];

const getCategoryCount = (category: string) => {
  return allNews.filter((news) => {
    const newsCategories = Array.isArray(news.data.category)
      ? news.data.category
      : [news.data.category];
    return newsCategories.includes(category);
  }).length;
};
---

<Layout title={`CCIIM - ${i18n.NAVBAR[6].TITLE.toUpperCase()}`}>
  <Banner CONTENT={i18n.NEWS} MT />
  <section class="max-w-7xl lg:mx-auto mx-6 mt-24 lg:mt-36 mb-24">
    <div class="flex flex-col-reverse lg:flex-row lg:gap-4 gap-12">
      <div
        class="flex-1 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
        id="news-grid"
      >
        {
          sortedNews.map((news) => (
            <div
              data-category={
                Array.isArray(news.data.category)
                  ? news.data.category.join(",")
                  : news.data.category
              }
              data-date={news.data.date.getTime()}
            >
              <CardNews
                title={news.data.title}
                description={news.data.description}
                image={news.data.image}
                slug={news.id.replace(".md", "")}
                lang={lang}
                readMoreText={i18n.NEWS.READ_MORE}
              />
            </div>
          ))
        }
      </div>
      <aside class="lg:w-[15%]">
        <div class="p-2 sticky top-24 flex flex-col gap-4">
          <div>
            <h3 class="!text-xl font-semibold mb-2">
              {i18n.NEWS.SORT_BY_DATE}
            </h3>
            <select
              id="sort-select"
              class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600"
            >
              <option value="newest">{i18n.NEWS.NEWEST_FIRST}</option>
              <option value="oldest">{i18n.NEWS.OLDEST_FIRST}</option>
            </select>
          </div>

          <div>
            <h3 class="!text-xl font-semibold mb-2">
              {i18n.NEWS.CATEGORIES}
            </h3>
            <ul class="space-y-1">
              <li class="flex items-center">
                <span class="mr-2">•</span>
                <button
                  data-category="all"
                  class="category-btn flex-1 text-left"
                >
                  <span class="!text-[var(--color-primary)] italic"
                    >{i18n.NEWS.ALL}
                  </span>
                  <span class="text-sm text-gray-500">({allNews.length})</span>
                </button>
              </li>
              {
                categories.map((category) => (
                  <li class="flex items-center">
                    <span class="mr-2">•</span>
                    <button
                      data-category={category}
                      class="category-btn flex-1 text-left"
                    >
                      <span class="!text-[var(--color-primary)] italic">
                        {category}{" "}
                      </span>
                      <span class="text-sm text-gray-500">
                        ({getCategoryCount(category)})
                      </span>
                    </button>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  let activeCategory = "all";
  let sortOrder: "newest" | "oldest" = "newest";

  function sortAndFilterNews() {
    const newsGrid = document.getElementById("news-grid");
    if (!newsGrid) return;

    const newsItems = Array.from(
      newsGrid.querySelectorAll(":scope > div"),
    ) as HTMLElement[];

    // Filter by category first
    const visibleItems: HTMLElement[] = [];
    const hiddenItems: HTMLElement[] = [];

    newsItems.forEach((item) => {
      const itemCategories =
        item.getAttribute("data-category")?.split(",") || [];
      if (activeCategory === "all" || itemCategories.includes(activeCategory)) {
        item.style.display = "block";
        visibleItems.push(item);
      } else {
        item.style.display = "none";
        hiddenItems.push(item);
      }
    });

    // Sort only visible items
    visibleItems.sort((a, b) => {
      const dateA = parseInt(a.getAttribute("data-date") || "0");
      const dateB = parseInt(b.getAttribute("data-date") || "0");
      return sortOrder === "newest" ? dateB - dateA : dateA - dateB;
    });

    // Clear grid and re-append: visible items first (sorted), then hidden items
    newsGrid.innerHTML = "";
    visibleItems.forEach((item) => newsGrid.appendChild(item));
    hiddenItems.forEach((item) => newsGrid.appendChild(item));
  }

  function updateCategoryButtons() {
    const buttons = document.querySelectorAll(".category-btn");
    buttons.forEach((btn) => {
      const btnCategory = btn.getAttribute("data-category");
      const span = btn.querySelector("span:first-child");
      const counter = btn.querySelector("span:last-child");

      if (btnCategory === activeCategory) {
        if (span) {
          span.classList.remove("font-medium");
          span.classList.add("font-bold");
        }
        if (counter) counter.classList.add("font-bold");
      } else {
        if (span) {
          span.classList.remove("font-bold");
          span.classList.add("font-medium");
        }
        if (counter) counter.classList.remove("font-bold");
      }
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    // Category filter
    const buttons = document.querySelectorAll(".category-btn");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category");
        if (category) {
          activeCategory = category;
          updateCategoryButtons();
          sortAndFilterNews();
        }
      });
    });

    // Sort select
    const sortSelect = document.getElementById(
      "sort-select",
    ) as HTMLSelectElement;
    if (sortSelect) {
      sortSelect.addEventListener("change", () => {
        sortOrder = sortSelect.value as "newest" | "oldest";
        sortAndFilterNews();
      });
    }

    updateCategoryButtons();
    sortAndFilterNews();
  });
</script>
