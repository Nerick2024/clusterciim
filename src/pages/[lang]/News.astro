---
import { getLangFromUrl, useTranslation } from "@/i18n";
import { translations } from "@/i18n/config";
import { getCollection } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import CardNews from "@/components/CardNews.astro";

export function getStaticPaths() {
  return Object.keys(translations).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const i18n = await useTranslation(lang);

const collectionName = `news-${lang}` as 'news-es' | 'news-en';
const allNews = await getCollection(collectionName);
const sortedNews = allNews.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(allNews.map(news => news.data.category))];

const getCategoryCount = (category: string) => {
  return allNews.filter(news => news.data.category === category).length;
};
---

<Layout title="CLUSTERCIIM">
  <Banner CONTENT={i18n.NEWS} MT />
  <section class="max-w-7xl lg:mx-auto mx-6 mt-24 lg:mt-36 mb-24">
    <div class="flex flex-col lg:flex-row gap-8">
      <div class="flex-1 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6" id="news-grid">
        {sortedNews.map((news) => (
          <div data-category={news.data.category} data-date={news.data.date.getTime()}>
            <CardNews
              title={news.data.title}
              description={news.data.description}
              image={news.data.image}
              slug={news.id.replace('.md', '')}
              lang={lang}
            />
          </div>
        ))}
      </div>
      <aside class="lg:w-64">
        <div class="bg-white rounded-lg shadow-lg p-6 sticky top-24 space-y-6">
          <div>
            <h3 class="text-xl font-bold mb-4">Sort by Date</h3>
            <select id="sort-select" class="w-full px-4 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-600">
              <option value="newest">Newest First</option>
              <option value="oldest">Oldest First</option>
            </select>
          </div>
          
          <div>
            <h3 class="text-xl font-bold mb-4">Categories</h3>
            <ul class="space-y-2">
              <li>
                <button 
                  data-category="all"
                  class="category-btn w-full flex justify-between items-center px-4 py-2 rounded transition-colors hover:bg-gray-100 text-left"
                >
                  <span>All</span>
                  <span class="text-sm font-semibold text-gray-500">({allNews.length})</span>
                </button>
              </li>
              {categories.map((category) => (
                <li>
                  <button 
                    data-category={category}
                    class="category-btn w-full flex justify-between items-center px-4 py-2 rounded transition-colors hover:bg-gray-100 text-left"
                  >
                    <span>{category}</span>
                    <span class="text-sm font-semibold text-gray-500">({getCategoryCount(category)})</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  let activeCategory = 'all';
  let sortOrder: 'newest' | 'oldest' = 'newest';

  function sortAndFilterNews() {
    const newsGrid = document.getElementById('news-grid');
    if (!newsGrid) return;

    const newsItems = Array.from(newsGrid.querySelectorAll(':scope > div')) as HTMLElement[];
    
    // Sort
    newsItems.sort((a, b) => {
      const dateA = parseInt(a.getAttribute('data-date') || '0');
      const dateB = parseInt(b.getAttribute('data-date') || '0');
      return sortOrder === 'newest' ? dateB - dateA : dateA - dateB;
    });
    
    // Clear and re-append in sorted order
    newsItems.forEach(item => newsGrid.appendChild(item));
    
    // Filter by category
    newsItems.forEach(item => {
      const itemCategory = item.getAttribute('data-category');
      if (activeCategory === 'all' || itemCategory === activeCategory) {
        item.style.display = 'block';
      } else {
        item.style.display = 'none';
      }
    });
  }

  function updateCategoryButtons() {
    const buttons = document.querySelectorAll('.category-btn');
    buttons.forEach(btn => {
      const btnCategory = btn.getAttribute('data-category');
      if (btnCategory === activeCategory) {
        btn.classList.add('bg-blue-600', 'text-white');
        btn.classList.remove('hover:bg-gray-100');
        const counter = btn.querySelector('span:last-child');
        if (counter) counter.classList.replace('text-gray-500', 'text-white');
      } else {
        btn.classList.remove('bg-blue-600', 'text-white');
        btn.classList.add('hover:bg-gray-100');
        const counter = btn.querySelector('span:last-child');
        if (counter) counter.classList.replace('text-white', 'text-gray-500');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Category filter
    const buttons = document.querySelectorAll('.category-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        if (category) {
          activeCategory = category;
          updateCategoryButtons();
          sortAndFilterNews();
        }
      });
    });
    
    // Sort select
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    if (sortSelect) {
      sortSelect.addEventListener('change', () => {
        sortOrder = sortSelect.value as 'newest' | 'oldest';
        sortAndFilterNews();
      });
    }
    
    updateCategoryButtons();
    sortAndFilterNews();
  });
</script>
